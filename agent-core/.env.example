# SWARM-18 Agent Core — Environment Configuration

# OAA Memory (file-based KV store)
OAA_MEMORY_DIR=./data
OAA_HMAC_KEY=change-this-to-a-random-256-bit-secret

# DVA cryptographic verification
DVA_VERIFICATION_KEY=change-this-to-a-random-signing-key

# HIVE world
HIVE_SYNC_INTERVAL_MS=5000
HIVE_WORLD_SEED=313

# Scheduler tick
SCHEDULER_TICK_MS=1000

# Sentinel health checks
SENTINEL_CHECK_INTERVAL_MS=60000

# Governance
GOVERNANCE_PROPOSAL_TTL_MS=86400000

# Logging
LOG_LEVEL=info
NODE_ENV=development
