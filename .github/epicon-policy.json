{
  "$comment": "EPICON tier policy for mobius-browser-shell. Declarative, proposer-independent (Rule 5.1). Unmatched paths classify EP-3 (Rule 5.2). PR tier = max across changed files (Rule 5.3).",
  "policy_id": "browser-shell-policy-v1",
  "EP-1": [
    "docs/**",
    "**/*.md",
    "*.md",
    "assets/**",
    "index.css",
    "CHANGELOG.md",
    "ARCHITECTURE.md"
  ],
  "EP-2": [
    "components/**",
    "src/**",
    "services/**",
    "hooks/**",
    "contexts/**",
    "errors/**",
    "utils/**",
    "types/**",
    "api/**",
    "scripts/**",
    "public/**",
    "sentinel/**",
    "oaa-api/**",
    "OAA-API-Library/**",
    "App.tsx",
    "index.html",
    "index.tsx",
    "constants.ts",
    "types.ts",
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    "vite.config.ts",
    "postcss.config.js",
    "metadata.json"
  ],
  "EP-3": [
    "agent-core/**",
    "config/**",
    ".github/workflows/**",
    "CODEOWNERS",
    "VERSION",
    "mobius.yaml",
    "vercel.json",
    "LICENSE"
  ]
}
