diff --git a/app/api/sentinel/paw-liveness/route.ts b/app/api/sentinel/paw-liveness/route.ts
index ac5a3e3..9ade7f0 100644
--- a/app/api/sentinel/paw-liveness/route.ts
+++ b/app/api/sentinel/paw-liveness/route.ts
@@ -1,5 +1,8 @@
 import { NextResponse } from 'next/server';
-import { kvGetSafe } from '@/lib/kv/store';
+import { kvGetRaw } from '@/lib/kv/store';
+
+/** Written by atlas-paw heartbeat cron at this exact Redis key (no second prefix). */
+const PAW_LIVENESS_RAW_KEY = 'mobius:atlas:paw:liveness';
 
 export const dynamic = 'force-dynamic';
 
@@ -7,10 +10,28 @@ type PawLiveness = {
   status: 'ok' | 'degraded' | 'down';
   ts: number;
   cycle?: string;
+  tripwireCount?: number;
   message?: string;
 };
 
+const STALE_MS = 25 * 60 * 60 * 1000; // 25h — matches PAW heartbeat TTL
+
 export async function GET() {
-  const paw = await kvGetSafe<PawLiveness>('atlas:paw:liveness');
-  return NextResponse.json(paw ?? null);
+  const paw = await kvGetRaw<PawLiveness>(PAW_LIVENESS_RAW_KEY);
+  if (!paw) {
+    return NextResponse.json({
+      status: 'down' as const,
+      ts: Date.now(),
+      message: 'atlas:paw:liveness missing — heartbeat may have missed',
+    });
+  }
+  const age = Date.now() - paw.ts;
+  if (age > STALE_MS) {
+    return NextResponse.json({
+      ...paw,
+      status: 'degraded' as const,
+      message: `PAW liveness stale (${Math.floor(age / 3_600_000)}h)`,
+    });
+  }
+  return NextResponse.json(paw);
 }
diff --git a/components/terminal/chambers/TripwireSparkline.tsx b/components/terminal/chambers/TripwireSparkline.tsx
