+    try {
+      tripwireCount = (await listTripwires("self")).length;
+    } catch {
+      tripwireCount = 0;
+    }
+    await writeTerminalLiveness({
+      ts: Date.now(),
+      status: "ok",
+      tripwireCount,
+      cycle,
+    });
+  }
 
   const payload = {
     agent: "ATLAS",
diff --git a/app/api/health/route.ts b/app/api/health/route.ts
index 8ceb289..523907c 100644
--- a/app/api/health/route.ts
+++ b/app/api/health/route.ts
@@ -1,13 +1,53 @@
 import { NextResponse } from "next/server";
-import { checkTunnelHealth } from "@/lib/openclaw";
+import { kvConfigured, kvPing } from "@/lib/kv";
+import { listTripwires } from "@/lib/tripwires/store";
 
 export const dynamic = "force-dynamic";
 
 export async function GET() {
-  const online = await checkTunnelHealth();
-  return NextResponse.json({
-    mode: online ? "full" : "readonly",
-    tunnelUrl: process.env.OPENCLAW_TUNNEL_URL || null,
-    checkedAt: new Date().toISOString(),
-  });
+  const checks: Record<string, string> = {};
+  let status: "ok" | "degraded" = "ok";
+
+  if (!kvConfigured()) {
+    checks.kv = "unconfigured";
+    status = "degraded";
+  } else {
+    try {
+      const pong = await kvPing();
+      checks.kv = pong ? "ok" : "error";
+      if (!pong) status = "degraded";
+    } catch {
+      checks.kv = "error";
+      status = "degraded";
+    }
+  }
+
+  let tripwireCount = 0;
+  try {
+    const tripwires = await listTripwires("self");
+    tripwireCount = tripwires.length;
+    checks.tripwires = `${tripwireCount} registered`;
+  } catch {
+    checks.tripwires = "error";
+    status = "degraded";
+  }
+
+  const tunnelOnline = Boolean(process.env.OPENCLAW_TUNNEL_URL?.trim());
+
+  return NextResponse.json(
+    {
+      status,
+      service: "atlas-paw",
+      ts: Date.now(),
+      checks: {
+        ...checks,
+        tunnel: tunnelOnline ? "configured" : "readonly",
+      },
+      tripwireCount,
+    },
+    {
+      status: status === "ok" ? 200 : 207,
+      headers: { "Cache-Control": "no-store" },
+    },
+  );
 }
diff --git a/lib/kv.ts b/lib/kv.ts
index d58de63..9848042 100644
--- a/lib/kv.ts
+++ b/lib/kv.ts
@@ -62,3 +62,30 @@ export async function kvDel(key: string): Promise<boolean> {
   })) as { result?: number } | null;
   return (body?.result ?? 0) > 0;
 }
+
+/** Upstash REST PING — used by /api/health liveness. */
+export async function kvPing(): Promise<boolean> {
+  if (!kvConfigured()) return false;
+  const body = (await kvCall("/ping")) as { result?: string } | null;
+  return body?.result === "PONG";
+}
+
+/**
+ * Terminal cross-read uses mobius-prefixed keys in the civic-ai-terminal KV layer.
+ * PAW writes the shared liveness blob here after each heartbeat.
+ */
+export const TERMINAL_LIVENESS_KEY = "mobius:atlas:paw:liveness";
+
+export type PawLivenessPayload = {
+  ts: number;
+  status: "ok" | "degraded";
+  tripwireCount: number;
+  cycle: string;
+};
+
+export async function writeTerminalLiveness(
+  payload: PawLivenessPayload,
+  ttlSeconds = 90_000,
+): Promise<boolean> {
+  return kvSet(TERMINAL_LIVENESS_KEY, payload, { ex: ttlSeconds });
+}
