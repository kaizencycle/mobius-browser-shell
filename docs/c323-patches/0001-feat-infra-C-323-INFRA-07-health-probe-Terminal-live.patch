@@ -10,7 +10,8 @@
 
 import { NextRequest, NextResponse } from "next/server";
 import { loadLastSeen } from "@/lib/atlas-gateway-state";
-import { kvConfigured } from "@/lib/kv";
+import { kvConfigured, writeTerminalLiveness } from "@/lib/kv";
+import { listTripwires } from "@/lib/tripwires/store";
 
 export const dynamic = "force-dynamic";
 
@@ -45,6 +46,24 @@ export async function GET(req: NextRequest) {
 
   const lastSeen = kvConfigured() ? await loadLastSeen() : null;
   const now = new Date().toISOString();
+  const cycle =
+    process.env.MOBIUS_CURRENT_CYCLE?.trim() ||
+    `C-${new Date().getUTCFullYear() % 100}${String(new Date().getUTCMonth() + 1).padStart(2, "0")}`;
+
+  let tripwireCount = 0;
