# Mobius Browser Shell — Environment Variables
# EPICON: Copy to .env.local for local dev. For Vercel, set in Dashboard.
#
# SERVER-SIDE ONLY (never expose to client):
#   GEMINI_API_KEY — Set in Vercel Dashboard → Settings → Environment Variables
#   AI requests route through /api/ai proxy; key never ships to browser.
#
# CLIENT-SIDE (VITE_ prefix — bundled into build):
#   See .env.local.example for full list of VITE_* lab URLs and feature flags.
#   VITE_TERMINAL_ORIGIN — Mobius Terminal base URL for snapshot fetches (default in env.ts).

# For local dev with api/ai proxy:
# GEMINI_API_KEY=your_key
#
# Run: vercel dev  (starts api/ai.ts on :3000; Vite on :5173)
#
# HIVE playable actions (C-289) — server-side only:
# OAA_API_BASE=https://oaa-api-library.onrender.com
# OAA_HIVE_MEMORY_PATH=/api/oaa/memory/append
# HIVE_ACTION_SKIP_EXTERNAL=true

# HIVE 16-bit world simulator (Higgsfield deploy) — optional, falls back to
# the hardcoded deploy URL in HiveGameEmbed.tsx when unset.
VITE_HIVE_URL=https://solid-crystal-164.higgsfield.gg/

# HIVE world JSON base (the /world/*.json substrate the shell reads). Leave
# empty to use the in-shell /api/hive/world edge proxy (recommended); set it to
# a static host or pinned tag for staging / release-pinned forks.
VITE_HIVE_WORLD_BASE_URL=
