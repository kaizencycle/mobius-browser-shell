# Mobius Browser Shell - Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# FRONTEND LABS (iframe targets)
# ============================================
# Set these to your deployed Render/Vercel URLs

# OAA Learning Hub
VITE_OAA_URL=https://lab7-proof.onrender.com

# Reflections
VITE_REFLECTIONS_URL=https://hive-api-2le8.onrender.com

# Citizen Shield
VITE_CITIZEN_SHIELD_URL=https://lab6-proof-api.onrender.com

# HIVE (optional - leave empty to use native RPG/portal demo)
VITE_HIVE_URL=

# Mobius Civic AI Terminal (snapshots / signals). No trailing slash.
VITE_TERMINAL_ORIGIN=https://mobius-civic-ai-terminal.vercel.app

# ── HIVE ↔ Shell data bridge ─────────────────────────────────────────────────
#
# How world JSON flows into the shell (priority order):
#
#  1. VITE_HIVE_WORLD_BASE_URL (set this for a custom host, fork, or pinned tag)
#  2. /api/hive/world  ← in-shell Vercel edge proxy (default; CDN-cached, no
#     GitHub Raw rate limits; see api/hive/world.ts + vercel.json rewrite)
#  3. raw.githubusercontent.com/kaizencycle/mobius-hive/main  ← direct fallback
#  4. /world/*.json bundled in public/  ← always works offline
#
# Leave VITE_HIVE_WORLD_BASE_URL empty to use the in-shell proxy (recommended).
# Set it to a deployed static HIVE host for staging / release-pinned branches.
VITE_HIVE_WORLD_BASE_URL=

# HIVE action API — the shell's documented write bridge.
# Player actions (interact, attest, earn) POST to /api/hive/action in the shell;
# that endpoint forwards telemetry to OAA memory and ATLAS events.
# OAA_API_BASE and OAA_HIVE_MEMORY_PATH control the forwarding destination.
OAA_HIVE_MEMORY_PATH=/api/oaa/memory/append
# Set to 'true' to skip external forwarding in local dev:
HIVE_ACTION_SKIP_EXTERNAL=false

# HIVE simulator portal integration:
# The HIVE MMO artifact opens the shell with ?chamber=<name> when a player
# clicks an O-portal. The shell reads this param on mount and navigates to
# the matching tab (oaa, jade, knowledge, shield, reflections, wallet, vault).
# No config needed — handled automatically by useChamberParam hook.
#
# To run the simulator locally:
#   cd /path/to/mobius-hive
#   npx serve . --listen 8787
#   open http://127.0.0.1:8787/artifacts/hive-mmo-simulator/

# ============================================
# BACKEND APIs
# ============================================

# OAA API Library
VITE_OAA_API_BASE=https://oaa-api-library.onrender.com

# Reflections API
VITE_REFLECTIONS_API_BASE=https://hive-api-2le8.onrender.com

# Citizen Shield API
VITE_CITIZEN_SHIELD_API_BASE=https://lab6-proof-api.onrender.com

# Command Ledger API
VITE_LEDGER_API=https://civic-protocol-core-ledger.onrender.com

# MIC Indexer API
VITE_MIC_API_BASE=https://gic-indexer.onrender.com

# Thought Broker API
VITE_THOUGHT_BROKER_API=https://mobius-systems.onrender.com

# Core API (OAA backend)
VITE_CORE_API_BASE=https://oaa-api-library.onrender.com

# Identity Service API
VITE_IDENTITY_API_BASE=https://mobius-identity-service.onrender.com

# MIC Wallet API (dedicated service or OAA API)
VITE_MIC_WALLET_API_BASE=https://mobius-mic-wallet-service.onrender.com

# ============================================
# FEATURE FLAGS
# ============================================

# Set to 'true' to embed live labs via iframe
# Set to 'false' to show demo UI components
VITE_USE_LIVE_LABS=true

# Enable MIC integration (set to 'true' when MIC system is ready)
VITE_MIC_ENABLED=false

# Use OAA API for MIC wallet operations (set to 'true' to use /api/mic/* endpoints on OAA API)
# When true, wallet calls go to VITE_OAA_API_BASE/api/mic/* instead of VITE_MIC_WALLET_API_BASE
VITE_USE_OAA_WALLET=true

# Enable debug mode (shows additional logging and load times)
VITE_DEBUG_MODE=true

# ============================================
# GEMINI (if using AI features)
# EPICON: Server-side only — set in Vercel Dashboard, never in client.
# AI requests route through /api/ai proxy; key never ships to browser.
# ============================================
GEMINI_API_KEY=your_key

# ============================================
# AUTH (server-side only — set in Vercel Dashboard, never prefix with VITE_)
# ============================================
# Symmetric secret for challenge HMAC and session JWT signing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHALLENGE_SECRET=your_challenge_secret
# JWT signed by auth/*/verify endpoints after successful WebAuthn assertion.
# Same secret; separate var for clarity. Replace with identity-service token
# endpoint when mobius-identity-service gains POST /citizens/:id/token.
JWT_SECRET=your_jwt_secret
# WebAuthn relying-party config
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:5173
# Pepper for citizenId derivation (HMAC of credential ID)
CITIZEN_ID_PEPPER=your_citizen_id_pepper
# Mobius identity service (optional — enables cross-device passkey lookup)
MOBIUS_IDENTITY_API_URL=https://mobius-identity-service.onrender.com
MOBIUS_IDENTITY_API_KEY=your_identity_api_key
